{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "lib": ["ES2022", "ESNext"],
    "maxNodeModuleJsDepth": 0,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"]
  },
  "include": [
    "eslint.config.js",
    "scripts/format-comment.cjs",
    "scripts/helpers.cjs",
    "scripts/release.mjs",
    "vitest.config.js"
  ],
  "exclude": [
    "coverage",
    "docs",
    "node_modules"
  ]
}
